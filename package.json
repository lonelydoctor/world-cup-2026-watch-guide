{
  "name": "world-cup-2026-watch-guide",
  "version": "0.1.0",
  "description": "Unofficial Chinese watch guide for the 2026 World Cup schedule, bracket, cities, teams, reminders, and rule-based concierge.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "refresh:data": "node scripts/refresh-worldcup-data.mjs",
    "test:data": "node scripts/test-data.mjs",
    "check:release": "npm run test:data && npm run typecheck && npm run lint && npm run build"
  },
  "keywords": [
    "world-cup",
    "fifa-world-cup-2026",
    "nextjs",
    "schedule",
    "bracket",
    "calendar",
    "chinese"
  ],
  "overrides": {
    "postcss": "$postcss"
  },
  "dependencies": {
    "flag-icons": "^7.3.2",
    "lucide-react": "^0.468.0",
    "next": "^15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
